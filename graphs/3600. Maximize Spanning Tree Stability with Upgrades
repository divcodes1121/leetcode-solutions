COMPLEXITY
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  Time  : O(E · α(N) · log E)   ← optimal for this problem
  Space : O(E + N)

  Key constant-factor optimizations over naive:
  - UF arrays allocated once, reset in-place (no GC pressure)
  - Optional edges sorted once, not inside each canAchieve call
  - Candidates stored as plain int[] not TreeSet (no boxing)
  - Single pass through opt edges with early break

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
JAVA SOLUTION
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
```java
import java.util.*;

class Solution {

    private int[] parent, ufRank;
    private int[][] optSorted, mustArr;

    private int find(int x) {
        while (parent[x] != x) {
            parent[x] = parent[parent[x]]; // path halving
            x = parent[x];
        }
        return x;
    }

    private boolean union(int x, int y) {
        int px = find(x), py = find(y);
        if (px == py) return false;
        if (ufRank[px] < ufRank[py]) { int t = px; px = py; py = t; }
        parent[py] = px;
        if (ufRank[px] == ufRank[py]) ufRank[px]++;
        return true;
    }

    public int maxStability(int n, int[][] edges, int k) {
        // Separate must vs optional edges
        int mc = 0, oc = 0;
        for (int[] e : edges) { if (e[3] == 1) mc++; else oc++; }
        mustArr   = new int[mc][];
        optSorted = new int[oc][];
        int mi = 0, oi = 0;
        for (int[] e : edges) {
            if (e[3] == 1) mustArr[mi++] = e;
            else           optSorted[oi++] = e;
        }

        // Sort optional edges DESC by strength — done ONCE, reused every BS call
        Arrays.sort(optSorted, (a, b) -> b[2] - a[2]);

        // Candidate answer values: every s and 2s, deduplicated
        int[] cands = new int[edges.length * 2];
        int ci = 0;
        for (int[] e : edges) { cands[ci++] = e[2]; cands[ci++] = e[2] * 2; }
        Arrays.sort(cands);
        int uci = 0;
        for (int i = 0; i < cands.length; i++) {
            if (i == 0 || cands[i] != cands[i - 1]) cands[uci++] = cands[i];
        }

        // Allocate UF arrays once — reset in-place each call, no GC
        parent = new int[n];
        ufRank = new int[n];

        if (!canAchieve(n, k, 1)) return -1;

        int lo = 0, hi = uci - 1, ans = 1;
        while (lo <= hi) {
            int mid = (lo + hi) >>> 1;
            if (canAchieve(n, k, cands[mid])) { ans = cands[mid]; lo = mid + 1; }
            else                               { hi = mid - 1; }
        }
        return ans;
    }

    private boolean canAchieve(int n, int k, int T) {
        // Reset UF in-place
        for (int i = 0; i < n; i++) { parent[i] = i; ufRank[i] = 0; }
        int used = 0;

        // 1. Must-edges: can't skip, can't upgrade
        for (int[] e : mustArr) {
            if (e[2] < T) return false;           // too weak, no fix possible
            if (!union(e[0], e[1])) return false; // forms a cycle
            used++;
        }

        // 2. Optional edges — single pass, pre-sorted DESC
        //    s >= T        → free (no upgrade)
        //    s >= ceil(T/2) → needs 1 upgrade
        //    s < ceil(T/2)  → useless even doubled → break early
        int halfT = (T + 1) >> 1;
        int spent = 0;

        for (int[] e : optSorted) {
            if (used == n - 1) break;
            int s = e[2];
            if (s >= T) {
                if (union(e[0], e[1])) used++;
            } else if (s >= halfT) {
                if (union(e[0], e[1])) { used++; spent++; }
            } else {
                break; // sorted DESC: nothing below qualifies
            }
        }

        return spent <= k && used == n - 1;
    }
}
