/*
 * ============================================================
 * 1878. Get Biggest Three Rhombus Sums in a Grid
 * Difficulty: Medium
 * ============================================================
 *
 * PROBLEM:
 * --------
 * You are given an m x n integer matrix grid.
 *
 * A rhombus sum is the sum of the elements that form the
 * BORDER of a regular rhombus shape in the grid.
 *
 * The rhombus must have the shape of a square rotated 45°
 * with each of the corners centered in a grid cell.
 *
 * Note: rhombus can have area 0 (just a single cell) ← very important!
 *
 * Return the biggest THREE DISTINCT rhombus sums in DESCENDING order.
 * If there are less than 3 distinct values, return all of them.
 *
 * ============================================================
 * EXAMPLES:
 * ============================================================
 *
 * Example 1:
 * ----------
 * Input:
 *   grid = [[3,4,5,1,3],
 *           [3,3,4,2,3],
 *           [20,30,200,40,10],
 *           [1,5,5,4,1],
 *           [4,3,2,2,5]]
 *
 * Output: [228, 216, 211]
 *
 * Why?
 *   Blue  → center(2,1) size1: 20 + 3  + 200 + 5  = 228
 *   Red   → center(2,3) size1: 200 + 2 + 10  + 4  = 216
 *   Green → center(3,2) size1: 200 + 5 + 4   + 2  = 211
 *
 * Visually (size 1 rhombus at center row2,col1):
 *
 *              (1,1)=3          ← TOP
 *             /       \
 *      (2,0)=20       (2,2)=200 ← LEFT and RIGHT
 *             \       /
 *              (3,1)=5          ← BOTTOM
 *
 *   Sum = 3 + 200 + 5 + 20 = 228 ✅
 *
 * -------------------------------------------------------
 * Example 2:
 * ----------
 * Input:
 *   grid = [[1,2,3],
 *           [4,5,6],
 *           [7,8,9]]
 *
 * Output: [20, 9, 8]
 *
 * Why?
 *   Blue  → center(1,1) size1: 4 + 2 + 6 + 8 = 20
 *   Red   → center(2,2) size0: just cell 9
 *   Green → center(2,1) size0: just cell 8
 *
 * -------------------------------------------------------
 * Example 3:
 * ----------
 * Input:  grid = [[7,7,7]]
 * Output: [7]
 *
 * Why?
 *   All cells are 7. All rhombuses (size 0 only, tiny grid)
 *   give sum = 7. TreeSet deduplicates → only one distinct value.
 *
 * ============================================================
 * CONSTRAINTS:
 * ============================================================
 *   m == grid.length
 *   n == grid[i].length
 *   1 <= m, n <= 50
 *   1 <= grid[i][j] <= 10^5
 *
 * ============================================================
 * APPROACH (think this before coding!):
 * ============================================================
 *
 * A rhombus is defined by TWO things:
 *   1. CENTER cell (i, j)
 *   2. SIZE s (how many steps from center to each corner)
 *
 * So our plan is:
 *   → Try EVERY cell as center         (nested i, j loops)
 *   → Try EVERY possible size          (inner s loop)
 *   → Calculate border sum each time   (getRhombusSum helper)
 *   → Keep track of top 3 distinct     (TreeSet of size 3)
 *
 * Size 0 rhombus = just the center cell (always valid!)
 *
 *   size 0:      size 1:      size 2:
 *                   *             *
 *     *           * * *         *   *
 *                   *          *     *
 *                               *   *
 *                                 *
 *
 * For a rhombus of size s, the 4 corners are:
 *   TOP    = (i-s, j)
 *   RIGHT  = (i,   j+s)
 *   BOTTOM = (i+s, j)
 *   LEFT   = (i,   j-s)
 *
 * We walk the border in 4 legs (like an ant walking around the diamond):
 *   Leg 1: TOP    → RIGHT   (go down-right)
 *   Leg 2: RIGHT  → BOTTOM  (go down-left)
 *   Leg 3: BOTTOM → LEFT    (go up-left)
 *   Leg 4: LEFT   → TOP     (go up-right)
 *
 * Each leg: start AT own corner, stop BEFORE next corner
 *           → loop k = 0 to k < s   (not k <= s!)
 *           → this prevents counting corners twice
 *
 * maxSize formula:
 *   → min(up, down, left, right) from center
 *   → stops the rhombus falling off the grid
 *   → up=i, down=rows-1-i, left=j, right=cols-1-j
 *
 * TreeSet of size 3:
 *   → add() sorts automatically + deduplicates
 *   → pollFirst() evicts smallest when size > 3
 *   → descendingSet() gives final answer in right order
 *
 * getRhombusSum 4 legs:
 *   Leg1: grid[i - s + k][j + k]      k=0 is TOP    corner
 *   Leg2: grid[i + k][j + s - k]      k=0 is RIGHT  corner
 *   Leg3: grid[i + s - k][j - k]      k=0 is BOTTOM corner
 *   Leg4: grid[i - k][j - s + k]      k=0 is LEFT   corner
 *
 * TIME COMPLEXITY:  O(m * n * min(m,n)^2)  → fine for 50x50 grid
 * SPACE COMPLEXITY: O(1) extra (TreeSet holds at most 4 elements)
 *
 * ============================================================
 */

import java.util.TreeSet;

class Solution {

    public int[] getBiggestThree(int[][] grid) {

        int rows = grid.length;
        int cols = grid[0].length;

        TreeSet<Integer> top3 = new TreeSet<>();

        for (int i = 0; i < rows; i++) {
            for (int j = 0; j < cols; j++) {

                int maxSize = Math.min(
                                Math.min(i, rows - 1 - i),
                                Math.min(j, cols - 1 - j)
                              );

                for (int s = 0; s <= maxSize; s++) {

                    int sum = getRhombusSum(grid, i, j, s);
                    top3.add(sum);

                    if (top3.size() > 3) {
                        top3.pollFirst();
                    }
                }
            }
        }

        int[] result = new int[top3.size()];
        int idx = 0;
        for (int val : top3.descendingSet()) {
            result[idx++] = val;
        }

        return result;
    }


    private int getRhombusSum(int[][] grid, int i, int j, int s) {

        if (s == 0) return grid[i][j];

        int sum = 0;

        for (int k = 0; k < s; k++) sum += grid[i - s + k][j + k];
        for (int k = 0; k < s; k++) sum += grid[i + k][j + s - k];
        for (int k = 0; k < s; k++) sum += grid[i + s - k][j - k];
        for (int k = 0; k < s; k++) sum += grid[i - k][j - s + k];

        return sum;
    }
}
